{
  "name": "zustand-chrome-storage",
  "version": "1.0.2",
  "description": "Zustand StateStorage based on chrome.storage API",
  "type": "module",
  "files": [
    "dist",
    "readme.md"
  ],
  "source": "src/index.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": "./dist/index.cjs",
    "default": "./dist/index.esm.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.esm.js",
  "unpkg": "./dist/index.umd.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "microbundle",
    "dev": "microbundle watch",
    "typecheck": "tsc --noEmit --strict --target es2020 --module esnext --moduleResolution bundler --lib es2020,dom --types chrome test/types.ts",
    "test": "npm run build && npm run typecheck && node --test test/*.test.cjs"
  },
  "keywords": [
    "zustand",
    "chrome",
    "storage"
  ],
  "author": "",
  "license": "ISC",
  "peerDependencies": {
    "zustand": ">=4.5.0 <6"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.0",
    "microbundle": "^0.15.1",
    "typescript": "^5.9.3",
    "zustand": "^5.0.14"
  }
}
